          "_name": "custom-html",
          "_customHTML": "<section mbr-id=\"_anchor\" class=\"mbr-section article content1\">\n\n    <mbr-parameters>\n    <!-- Block parameters controls (Blue \"Gear\" panel) -->\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"8\" step=\"1\" value=\"3\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"8\" step=\"1\" value=\"1\">\n        <input type=\"color\" title=\"Background Color\" name=\"bgColor\" value=\"#efefef\">\n    <!-- End block parameters -->\n    </mbr-parameters> \n\n    <div class=\"container\">\n        <div class=\"media-container-row\">\n            <div class=\"mbr-text col-12 col-md-12\">\n                \n              \n              <p align=\"center\"><iframe width=80% height=\"500\" src=\"https://app.powerbi.com/view?r=eyJrIjoiYjcxNjY2OTAtZDZjYS00NDM1LTg3YjMtNzc2MGM1ZTJmNzVmIiwidCI6IjcxNjYzMDUzLTNhOGUtNDM0MC1hNTVhLTVhOTc4YTcxOTY0YyJ9&pageName=ReportSectione2500ec98529caad9b8c\" frameborder=\"0\" allowFullScreen=\"true\"></iframe></p>\n              \n              \n            </div>\n        </div>\n    </div>\n</section>",
          "_isUserblock": true,
          "_sourceTheme": "mobirise4",
