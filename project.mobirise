    "Sprocket.html": {
      "settings": {
        "meta_descr": "Sprocket is a project I developed to help a fictional bike company determine which customers to target based on customer demographics.",
        "title": "Sprocket",
        "order": 16
      },
      "components": [
        {
          "alias": false,
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 15px)",
              "padding-bottom": "(@paddingBottom * 15px)"
            },
